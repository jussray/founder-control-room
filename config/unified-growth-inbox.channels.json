      "outbound_prerecorded_or_ai_voice_sales_calls",
      "call_recording_or_transcription",
      "minor_directed_marketing",
      "sensitive_data_processing",
      "multi_jurisdiction_campaigns",
      "paid_reservations_or_custom_financial_terms"
    ]
