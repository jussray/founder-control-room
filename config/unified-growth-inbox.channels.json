{
  "schemaVersion": 1,
  "updatedAt": "2026-07-18",
  "reviewedAgainstPublicGuidanceAt": "2026-07-17",
  "mission": "Generate lawful, attributable revenue from permission-based conversations while preserving founder authority, brand, privacy, consent, and project separation.",
  "defaultAutomationMode": "draft_only",
  "supportedAutomationModes": [
    "observe_only",
    "draft_only",
    "inbound_assist",
    "approved_sequence",
    "trusted_rules"
  ],
  "revenueAccounting": {
    "recognizedRevenueState": "payment_collected",
    "separateStates": [
      "attention",
      "permission",
      "conversation",
      "qualified",
      "booked",
      "invoiced",
      "pledged",
      "payment_collected",
      "refunded",
      "charged_back",
      "retained",
      "referred"
    ],
    "forbidReportingAsCollected": [
      "waitlist_joined",
      "lead_created",
      "projected_value",
      "booked_value",
      "invoice_sent",
      "sponsorship_pledged"
    ]
  },
  "globalRules": {
    "coldOutreachEnabled": false,
    "humanApprovalRequiredForNewCampaign": true,
    "humanApprovalRequiredForOutboundCalls": true,
    "humanApprovalRequiredForPricingOrDiscounts": true,
    "crossProjectTargetingEnabled": false,
    "sensitiveDataSalesUseEnabled": false,
    "purchasedScrapedOrInferredListsAllowed": false,
    "projectSpecificConsentRequired": true,
    "purposeSpecificConsentRequired": true,
    "proofOfConsentRequired": true,
    "globalSuppressionOverridesCampaigns": true,
    "automationDisclosureRequired": true,
    "legalPolicyGateRequired": true,
    "providerPolicyEvidenceRequired": true,
    "claimEvidenceRequired": true,
    "auditAndIdempotencyRequiredBeforeDispatch": true,
    "recordingDefaultEnabled": false,
    "transcriptionDefaultEnabled": false,
    "syntheticVoiceDefaultEnabled": false,
    "minorDirectedMarketingDefaultEnabled": false
  },
  "legalPolicyGate": {
    "requiredChecks": [
      "sender_identity_verified",
      "project_and_purpose_known",
      "recipient_identity_sufficiently_resolved",
      "consent_or_valid_inbound_context_verified",
      "consent_evidence_retained",
      "channel_window_or_approved_template_verified",
      "global_project_channel_and_campaign_suppression_clear",
      "age_and_sensitive_data_boundary_clear",
      "jurisdiction_rules_resolved",
      "quiet_hours_resolved",
      "sender_campaign_or_telemarketer_registration_resolved",
      "content_offer_and_claims_approved",
      "required_disclosures_present",
      "opt_out_path_verified",
      "frequency_budget_and_kill_switch_present",
      "retention_and_audit_policy_present",
      "provider_terms_and_permissions_current",
      "idempotency_and_dispatch_audit_ready"
    ],
    "failClosedOnUnknown": true,
    "denyStates": [
      "unknown",
      "conflict",
      "expired",
      "missing_evidence"
    ],
    "pennsylvaniaTelemarketing": {
      "outboundSalesCallsEnabled": false,
      "requiredBeforeEnablement": [
        "qualified_counsel_registration_or_exemption_decision",
        "pennsylvania_telemarketer_registration_status",
        "bonding_or_deposit_status_if_required",
        "pennsylvania_do_not_call_subscription_and_screening_status",
        "national_do_not_call_screening_status",
        "internal_do_not_call_process",
        "calling_hours_and_disclosure_policy",
        "artificial_prerecorded_or_synthetic_voice_consent_policy",
        "recording_and_transcription_consent_policy"
      ]
    },
    "requiresQualifiedLegalReviewBefore": [
      "broad_automated_marketing",
      "outbound_prerecorded_or_ai_voice_sales_calls",
      "call_recording_or_transcription",
      "minor_directed_marketing",
      "sensitive_data_processing",
      "multi_jurisdiction_campaigns",
      "paid_reservations_or_custom_financial_terms"
    ]
  },
  "projectBoundary": {
    "crossProjectConsentReuse": false,
    "probabilisticIdentityAutoMerge": false,
