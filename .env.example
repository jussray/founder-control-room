# RepositoryProvider (GitHub, Phase 1)
GITHUB_TOKEN=
GITHUB_DEFAULT_OWNER=jussray

# This project's OWN Supabase project — never Bip's.
# Project ref: oojzfmmywbvficgybaxd (founder-control-room)
SUPABASE_URL=https://oojzfmmywbvficgybaxd.supabase.co
SUPABASE_SERVICE_ROLE_KEY=

# Founder authentication uses the private public.founder_users allowlist.
# Do not mirror founder identities into environment variables or client code.
# The browser magic-link flow uses a publishable key, never service_role.
SUPABASE_PUBLISHABLE_KEY=sb_publishable_Gio6mqYWCgVokBJWclKUlw_iH7KADpa
# Temporary compatibility fallback for older Worker secret names only:
SUPABASE_ANON_KEY=

# HTTP server
PORT=8787
NODE_ENV=development

# Guarded terminal — disabled and loopback-only by default.
# The workspace root must contain reviewed checkouts named by the command
# registry, for example:
#   <root>/founder-control-room
#   <root>/jbh-private
#   <root>/jussbeautifulhair-site
#   <root>/untold-stories-storefront
CONTROL_ROOM_TERMINAL_ENABLED=false
CONTROL_ROOM_TERMINAL_ALLOW_REMOTE=false
CONTROL_ROOM_WORKSPACE_ROOT=

# ---------------------------------------------------------------------------
# FOUNDER BROWSER ONBOARDING URLS
# ---------------------------------------------------------------------------
#
# FOUNDER_API_URL
#   The public origin of THIS backend and onboarding UI.
#   Magic links return to:
#     ${FOUNDER_API_URL}/auth/callback
#   Add that exact URL to Supabase Auth > URL Configuration > Redirect URLs.
#
# FOUNDER_ALLOWED_ORIGINS
#   Comma-separated browser origins allowed to call this API.
#   For the same-origin onboarding UI, include FOUNDER_API_URL itself.
#
# These values are required in production and must use HTTPS. Defaults are
# localhost-only for development.
# ---------------------------------------------------------------------------
FOUNDER_API_URL=http://localhost:8787
FOUNDER_ALLOWED_ORIGINS=http://localhost:8787
