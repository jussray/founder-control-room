# RepositoryProvider (GitHub, Phase 1)
GITHUB_TOKEN=
GITHUB_DEFAULT_OWNER=jussray

# This project's OWN Supabase project — never Bip's.
# Project ref: oojzfmmywbvficgybaxd (founder-control-room)
SUPABASE_URL=https://oojzfmmywbvficgybaxd.supabase.co
SUPABASE_SERVICE_ROLE_KEY=

# Founder auth (separate identity from Bip's consumer auth)
FOUNDER_EMAIL=mcgill.raylene@gmail.com

# Publishable/anon key — safe to expose, this is what the auth flow
# (magic link send + verify) runs on. Never use the service role key here.
SUPABASE_PUBLISHABLE_KEY=sb_publishable_Gio6mqYWCgVokBJWclKUlw_iH7KADpa

# HTTP server
PORT=8787
NODE_ENV=development

# Guarded terminal — disabled and loopback-only by default.
# The workspace root must contain reviewed checkouts named by the command
# registry, for example:
#   <root>/founder-control-room
#   <root>/jbh-private
#   <root>/jussbeautifulhair-site
#   <root>/untold-stories-storefront
CONTROL_ROOM_TERMINAL_ENABLED=false
CONTROL_ROOM_TERMINAL_ALLOW_REMOTE=false
CONTROL_ROOM_WORKSPACE_ROOT=

# ---------------------------------------------------------------------------
# URL SETTINGS — two separate variables, intentionally distinct
# ---------------------------------------------------------------------------
#
# FOUNDER_API_URL
#   The public base URL of THIS backend server.
#   The magic-link email will redirect the founder to:
#     ${FOUNDER_API_URL}/auth/callback
#   This must reach the backend, not the frontend.
#   In a split-origin deployment:
#     FOUNDER_API_URL=https://api.control.example.com
#
# FOUNDER_ALLOWED_ORIGINS
#   Comma-separated list of browser frontend origins that are allowed to make
#   cross-origin requests to this API (CORS allowed origins).
#   Normalized via URL().origin — trailing slashes are stripped automatically.
#   In a split-origin deployment:
#     FOUNDER_ALLOWED_ORIGINS=https://control.example.com
#   Multiple origins:
#     FOUNDER_ALLOWED_ORIGINS=https://control.example.com,https://staging.control.example.com
#
# THESE MUST BE SEPARATE VALUES.
# FOUNDER_API_URL is the backend URL.
# FOUNDER_ALLOWED_ORIGINS is the frontend origin.
# Both are required in production (NODE_ENV=production).
# Defaults to localhost in development.
# ---------------------------------------------------------------------------
FOUNDER_API_URL=http://localhost:8787
FOUNDER_ALLOWED_ORIGINS=http://localhost:3000,http://localhost:8787
