# RepositoryProvider (GitHub, Phase 1)
# Production authority: repository-scoped GitHub App installation tokens.
GITHUB_APP_ID=
GITHUB_PRIVATE_KEY=
GITHUB_WEBHOOK_SECRET=

# Local/development fallback only. Do not make a personal token authoritative.
GITHUB_TOKEN=

# Optional signed repo-runner pings. Prefer a distinct secret per repository:
# REPOSITORY_INGEST_SECRET_SEKRET_BIP=
# REPOSITORY_INGEST_SECRET_FOUNDER_CONTROL_ROOM=
REPOSITORY_INGEST_SECRET=

# This project's OWN Supabase project — never a product project's database.
SUPABASE_URL=https://YOUR_FOUNDER_CONTROL_ROOM_PROJECT.supabase.co
SUPABASE_SERVICE_ROLE_KEY=

# Local/admin Postgres smoke test only. Never expose this in frontend code.
# Percent-encode the password if it contains special characters.
DATABASE_URL=postgresql://postgres:[YOUR-PASSWORD]@db.YOUR_FOUNDER_CONTROL_ROOM_PROJECT.supabase.co:5432/postgres?sslmode=require

# Publishable key used only for founder magic-link/session auth.
SUPABASE_PUBLISHABLE_KEY=

# Founder allowlist bootstrap/operations. Use your own founder email locally.
FOUNDER_EMAIL=founder@example.com

# HTTP server
PORT=8787
NODE_ENV=development

# Guarded terminal — disabled and loopback-only by default.
# The workspace root must contain reviewed checkouts named by the command
# registry, for example:
#   <root>/founder-control-room
#   <root>/jbh-private
#   <root>/jussbeautifulhair-site
#   <root>/untold-stories-storefront
CONTROL_ROOM_TERMINAL_ENABLED=false
CONTROL_ROOM_TERMINAL_ALLOW_REMOTE=false
CONTROL_ROOM_WORKSPACE_ROOT=

# MCP Hub — endpoint values and bearer tokens stay local/secret.
# Leave an endpoint blank to keep that server disabled.
# Phase 1 permits only zero-cost read-only tools.
MCP_REQUEST_TIMEOUT_MS=10000
MCP_GITHUB_URL=
MCP_GITHUB_TOKEN=
MCP_PLAYWRIGHT_URL=
MCP_PLAYWRIGHT_TOKEN=
MCP_FIGMA_URL=
MCP_FIGMA_TOKEN=
MCP_SUPABASE_DEV_URL=
MCP_SUPABASE_DEV_TOKEN=

# ---------------------------------------------------------------------------
# URL SETTINGS — two separate variables, intentionally distinct
# ---------------------------------------------------------------------------
#
# FOUNDER_API_URL
#   The public base URL of THIS backend server. Browser magic links return
#   here, establish HttpOnly same-origin cookies, and redirect into
#   /control-room. The magic-link email will redirect the founder to:
#     ${FOUNDER_API_URL}/auth/callback
#   This must reach the backend, not the frontend.
#   In a split-origin deployment:
#     FOUNDER_API_URL=https://api.control.example.com
#
# FOUNDER_ALLOWED_ORIGINS
#   Comma-separated list of browser frontend origins that are allowed to make
#   cross-origin requests to this API (CORS allowed origins).
#   Normalized via URL().origin — trailing slashes are stripped automatically.
#   In a split-origin deployment:
#     FOUNDER_ALLOWED_ORIGINS=https://control.example.com
#   Multiple origins:
#     FOUNDER_ALLOWED_ORIGINS=https://control.example.com,https://staging.control.example.com
#
# THESE MUST BE SEPARATE VALUES.
# FOUNDER_API_URL is the backend URL.
# FOUNDER_ALLOWED_ORIGINS is the frontend origin.
# Both are required in production (NODE_ENV=production).
# Defaults to localhost in development.
# ---------------------------------------------------------------------------
FOUNDER_API_URL=http://localhost:8787

# Browser origins allowed to call this API. The bundled dashboard is same-origin;
# localhost:3000 is retained only for optional local frontend development.
FOUNDER_ALLOWED_ORIGINS=http://localhost:8787,http://localhost:3000
