{
  "compilerOptions": {
    "target": "ES2022",
    "module": "NodeNext",
    "moduleResolution": "NodeNext",
    "lib": ["ES2022"],
    "outDir": "dist",
    "rootDir": "src",
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "resolveJsonModule": true,
    "declaration": true,
    "sourceMap": true
  },
  "include": ["src"],
  "exclude": [
    "src/app/**/*",
    "src/components/**/*",
    "src/lib/contracts.ts",
    "src/lib/data.ts",
    "src/lib/db-types.ts",
    "src/lib/queries.ts",
    "src/lib/supabase.ts",
    "src/lib/types.ts",
    "src/worker/index.ts"
  ]
}
