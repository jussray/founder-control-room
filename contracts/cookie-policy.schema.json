{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://founder-control-room.local/contracts/cookie-policy.schema.json",
  "title": "Portfolio Cookie and Session Policy",
  "type": "object",
  "additionalProperties": false,
  "required": ["schemaVersion", "repository", "runtimeClass", "firstPartyCookies", "platformManagedCookies", "browserStorage", "forbidden"],
  "properties": {
    "schemaVersion": { "const": 1 },
    "repository": { "type": "string", "pattern": "^[^/]+/[^/]+$" },
    "runtimeClass": { "enum": ["server_web_app", "native_rich_client", "static_spa", "shopify_hydrogen", "local_only_admin", "runtime_service"] },
    "firstPartyCookies": { "type": "array", "items": { "$ref": "#/$defs/cookie" } },
    "platformManagedCookies": { "type": "array", "items": { "$ref": "#/$defs/platformCookie" } },
    "browserStorage": { "type": "array", "items": { "$ref": "#/$defs/storage" } },
    "forbidden": { "type": "array", "minItems": 1, "items": { "type": "string", "minLength": 3 } },
    "notes": { "type": "array", "items": { "type": "string" } }
  },
  "$defs": {
    "cookie": {
      "type": "object",
      "additionalProperties": false,
      "required": ["name", "purpose", "classification", "owner", "httpOnly", "secureInProduction", "sameSite", "path", "maxAgeSeconds", "source"],
      "properties": {
        "name": { "type": "string", "minLength": 1 },
        "purpose": { "type": "string", "minLength": 8 },
        "classification": { "const": "strictly_necessary" },
        "owner": { "enum": ["backend", "platform"] },
        "httpOnly": { "type": "boolean" },
        "secureInProduction": { "const": true },
        "sameSite": { "enum": ["Strict", "Lax", "None"] },
        "path": { "type": "string", "pattern": "^/" },
        "maxAgeSeconds": { "type": "integer", "minimum": 0, "maximum": 31536000 },
        "source": { "type": "string", "minLength": 3 },
        "environments": { "type": "array", "items": { "enum": ["development", "preview", "production"] } }
      }
    },
    "platformCookie": {
      "type": "object",
      "additionalProperties": false,
      "required": ["provider", "purpose", "classification", "control"],
      "properties": {
        "provider": { "type": "string", "minLength": 2 },
        "names": { "type": "array", "items": { "type": "string" } },
        "purpose": { "type": "string", "minLength": 8 },
        "classification": { "const": "strictly_necessary" },
        "control": { "enum": ["provider_managed", "repository_configured"] }
      }
    },
    "storage": {
      "type": "object",
      "additionalProperties": false,
      "required": ["surface", "mechanism", "purpose", "sensitive"],
      "properties": {
        "surface": { "enum": ["native", "web", "server"] },
        "mechanism": { "enum": ["SecureStore", "AsyncStorage", "localStorage", "memory", "database"] },
        "purpose": { "type": "string", "minLength": 8 },
        "sensitive": { "type": "boolean" }
      }
    }
  }
}
