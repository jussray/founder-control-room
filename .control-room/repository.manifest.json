{
  "schemaVersion": "1.0",
  "projectId": "founder-control-room",
  "repository": {
    "provider": "github",
    "identifier": "jussray/founder-control-room",
    "defaultBranch": "main"
  },
  "verification": {
    "requiredSignals": [
      {
        "id": "typecheck",
        "name": "Type check",
        "required": true
      },
      {
        "id": "lint",
        "name": "Lint",
        "required": true
      },
      {
        "id": "tests",
        "name": "Test",
        "required": true
      }
    ]
  },
  "capabilities": [
    {
      "id": "provider-agnostic-repository-control",
      "description": "Reads and changes repositories through a provider-neutral interface instead of direct GitHub coupling.",
      "status": "active",
      "evidencePaths": [
        "src/providers/RepositoryProvider.ts",
        "src/providers/GitHubProvider.ts",
        "src/providers/providerFactory.ts"
      ],
      "requiredSignals": [
        "typecheck",
        "tests"
      ]
    },
    {
      "id": "federated-repository-verification",
      "description": "Identifies exact repo commits, checks manifest claims against code paths and CI signals, and stores sanitized drift evidence.",
      "status": "active",
      "evidencePaths": [
        "src/types/repositoryVerification.ts",
        "src/services/repositoryVerification.ts",
        "src/services/repositoryEvidenceStore.ts",
        "src/http/routes/repositoryVerification.ts",
        "src/http/routes/portfolioVerification.ts",
        "supabase/migrations/20260715070000_federated_repository_verification.sql",
        "supabase/migrations/20260715071000_fix_repository_verification_packet_dedupe.sql"
      ],
      "requiredSignals": [
        "typecheck",
        "lint",
        "tests"
      ]
    },
    {
      "id": "sanitized-provider-event-ingestion",
      "description": "Routes GitHub events using the raw body in memory but persists only allowlisted operational fields without messages, PR text, people, emails, secrets, or unknown payload fields.",
      "status": "active",
      "evidencePaths": [
        "src/http/webhooks/github.ts",
        "src/providers/githubEventSanitizer.ts",
        "src/providers/githubEventSanitizer.test.ts"
      ],
      "requiredSignals": [
        "typecheck",
        "lint",
        "tests"
      ]
    },
    {
      "id": "scheduled-portfolio-reconciliation",
      "description": "Enqueues only due main-portfolio repositories, preserves provider retry backoff, verifies them through ManifestController, and excludes the demo project.",
      "status": "active",
      "evidencePaths": [
        "src/controllers/ManifestController.ts",
        "src/services/portfolioVerificationScheduler.ts",
        "src/services/portfolioVerificationContract.test.ts",
        "src/worker/reconciler.ts",
        "src/worker/cf-entry.ts",
        "src/events/outbox.ts",
        "src/controllers/base.ts",
        "supabase/migrations/20260715072000_schedule_portfolio_repository_verification.sql",
        "supabase/migrations/20260715073000_harden_reconciliation_queue_and_leases.sql"
      ],
      "requiredSignals": [
        "typecheck",
        "lint",
        "tests"
      ]
    },
    {
      "id": "approval-gated-build-assist",
      "description": "Converts verified drift into proposed missions without carrying approval into branch, integration, deploy, or rollback actions.",
      "status": "active",
      "evidencePaths": [
        "src/controllers/ManifestController.ts",
        "src/http/routes/repositoryVerification.ts",
        "src/http/routes/approvals.ts",
        "src/types/mission.ts"
      ],
      "requiredSignals": [
        "typecheck",
        "tests"
      ]
    },
    {
      "id": "separate-founder-data-boundary",
      "description": "Uses a dedicated founder-operations Supabase project and accepts only sanitized operational evidence from product repos.",
      "status": "active",
      "evidencePaths": [
        "src/lib/supabaseClient.ts",
        "docs/ARCHITECTURE.md",
        "supabase/migrations/0001_init.sql"
      ],
      "requiredSignals": [
        "typecheck"
      ]
    }
  ],
  "buildAssist": {
    "enabled": true,
    "preferredBuilder": "codex",
    "riskLevel": "high"
  },
  "privacy": {
    "allowlistedPacketFields": [
      "projectId",
      "repository.provider",
      "repository.identifier",
      "commitSha",
      "branch",
      "manifestHash",
      "generatedAt",
      "runner.provider",
      "runner.runId",
      "runner.detailsUrl",
      "checks.id",
      "checks.name",
      "checks.required",
      "checks.status",
      "checks.detailsUrl",
      "capabilities.id",
      "capabilities.claimedStatus",
      "capabilities.observedStatus",
      "capabilities.evidencePaths",
      "capabilities.reason"
    ],
    "forbiddenData": [
      "source code contents",
      "commit messages",
      "pull request title or body",
      "provider sender, user, author, reviewer, or committer identities",
      "email addresses",
      "secrets or credentials",
      "raw logs containing secrets",
      "customer or user content",
      "voice transcripts",
      "private product database rows"
    ]
  }
}
