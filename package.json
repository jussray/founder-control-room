{
  "name": "founder-control-room",
  "version": "1.0.0",
  "type": "module",
  "scripts": {
    "test": "vitest run",
    "build": "tsc -p tsconfig.json",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "dev": "tsx watch src/index.ts",
    "start": "node dist/index.js",
    "cf:dev": "wrangler dev src/worker/cf-entry.ts --port 8787",
    "deploy": "wrangler deploy"
  },
  "dependencies": {
    "@octokit/rest": "^21.0.2",
    "@supabase/supabase-js": "^2.47.2",
    "dotenv": "^16.4.5",
    "express": "^4.21.2"
  },
  "devDependencies": {
    "@cloudflare/workers-types": "^4.20250620.0",
    "@types/express": "^4.17.21",
    "@types/node": "^22.5.4",
    "tsx": "^4.19.0",
    "typescript": "^5.5.4",
    "wrangler": "^3.114.7"
  },
  "engines": {
    "node": ">=20"
  }
}
