{
  "name": "founder-control-room",
  "version": "0.1.0",
  "private": true,
  "license": "UNLICENSED",
  "type": "module",
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "typecheck:design-os": "tsc -p tsconfig.design-os.json",
    "dev": "tsx watch src/index.ts",
    "start": "node dist/index.js",
    "cf:dev": "wrangler dev --config wrangler.toml --port 8787",
    "cf:dev:api": "wrangler dev --config wrangler.api.toml --port 8788",
    "deploy": "wrangler deploy --config wrangler.toml",
    "deploy:api": "wrangler deploy --config wrangler.api.toml",
    "lint": "eslint 'src/**/*.ts'",
    "lint:design-os": "eslint 'src/design-os/**/*.ts' 'src/http/routes/designOs.ts' 'src/http/routes/designOs.test.ts' --max-warnings 0",
    "test": "vitest run",
    "test:e2e": "npm run build && node e2e/run.mjs",
    "preview:evidence": "node scripts/import-preview-evidence.mjs",
    "verify:mcp": "node scripts/verify-mcp-config.mjs",
    "verify:terminal-contract": "node scripts/verify-guarded-terminal-contract.mjs",
    "verify:ai-skills": "node scripts/verify-ai-skill-contract.mjs",
    "verify:cookies": "node scripts/verify-cookie-contract.mjs",
    "verify:founder-onboarding": "node scripts/verify-founder-onboarding.mjs",
    "verify:growth-inbox": "node scripts/verify-unified-growth-inbox.mjs",
    "verify:design-os": "node scripts/verify-design-os-contract.mjs && vitest run --config vitest.design-os.config.ts",
    "verify:local-workspace": "node scripts/verify-local-workspace.mjs",
    "verify:rls-contract": "node scripts/verify-rls-contract.mjs"
  },
  "dependencies": {
    "@octokit/rest": "^21.0.2",
    "@supabase/supabase-js": "^2.45.4",
    "cors": "^2.8.6",
    "dotenv": "^16.4.5",
    "express": "^4.21.2",
    "express-rate-limit": "^8.5.2",
    "helmet": "^8.3.0"
  },
  "devDependencies": {
    "@cloudflare/workers-types": "^5.20260708.1",
    "@playwright/test": "^1.45.0",
    "@types/cors": "^2.8.19",
    "@types/express": "^4.17.21",
    "@types/node": "^22.5.4",
    "@types/supertest": "^6.0.0",
    "@typescript-eslint/eslint-plugin": "^8.0.0",
    "@typescript-eslint/parser": "^8.0.0",
    "@vitest/coverage-v8": "^4.1.10",
    "eslint": "^9.0.0",
    "playwright": "^1.61.1",
    "supertest": "^7.0.0",
    "tsx": "^4.19.0",
    "typescript": "^5.5.4",
    "vitest": "^4.1.10",
    "wait-on": "^7.2.0",
    "wrangler": "^4.110.0"
  },
  "engines": {
    "node": ">=20"
  }
}
