{
  "name": "founder-control-room",
  "version": "0.1.0",
  "private": true,
  "description": "Standalone, provider-independent Control Room backend for Se'kret Bip and future projects.",
  "type": "module",
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "dev": "tsx watch src/index.ts",
    "start": "node dist/index.js",
    "start:test": "tsx src/index.ts",
    "test:e2e": "playwright test",
    "test:guardrails": "playwright test e2e/guardrails.spec.ts"
  },
  "dependencies": {
    "@octokit/rest": "^21.0.2",
    "@supabase/supabase-js": "^2.45.4",
    "dotenv": "^16.4.5",
    "express": "^4.21.2"
  },
  "devDependencies": {
    "@playwright/test": "^1.61.1",
    "@types/express": "^4.17.21",
    "@types/node": "^22.5.4",
    "tsx": "^4.19.0",
    "typescript": "^5.5.4"
  },
  "engines": {
    "node": ">=20"
  }
}
